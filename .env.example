# Puertos publicados al host por el proxy
LAB_HTTP_PORT=8080         # landing + ruteo
LAB_DVWA_PORT=8081         # acceso directo a DVWA
LAB_JUICE_PORT=8082        # acceso directo a Juice Shop
LAB_STATUS_PORT=8088       # /nginx_status expuesto

# Credenciales de la base de datos
MYSQL_ROOT_PASSWORD=root
